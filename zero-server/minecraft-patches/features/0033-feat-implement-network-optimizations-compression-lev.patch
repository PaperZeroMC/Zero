diff --git a/net/minecraft/network/Connection.java b/net/minecraft/network/Connection.java
index 0075ba2269ec767164fc92d4a82ace213ced75e0..e2195ab9ca024cda709d89d734c44a2a2c2ffd96 100644
--- a/net/minecraft/network/Connection.java
+++ b/net/minecraft/network/Connection.java
@@ -789,7 +789,11 @@ public class Connection extends SimpleChannelInboundHandler<Packet<?>> {
     // Paper end - add proper async disconnect
     public void setupCompression(int threshold, boolean validateDecompressed) {
         if (threshold >= 0) {
-            com.velocitypowered.natives.compression.VelocityCompressor compressor = com.velocitypowered.natives.util.Natives.compress.get().create(io.papermc.paper.configuration.GlobalConfiguration.get().misc.compressionLevel.or(-1)); // Paper - Use Velocity cipher
+            // Zero start - use configured compression level
+            int compressionLevel = cn.zeromc.zero.PurpurConfig.networkCompressionLevel;
+            if (compressionLevel < 0) compressionLevel = io.papermc.paper.configuration.GlobalConfiguration.get().misc.compressionLevel.or(-1);
+            com.velocitypowered.natives.compression.VelocityCompressor compressor = com.velocitypowered.natives.util.Natives.compress.get().create(compressionLevel); // Paper - Use Velocity cipher
+            // Zero end
             if (this.channel.pipeline().get("decompress") instanceof CompressionDecoder compressionDecoder) {
                 compressionDecoder.setThreshold(compressor, threshold, validateDecompressed); // Paper - Use Velocity cipher
             } else {
